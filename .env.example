# ===============================
# DingTalk Credentials (required)
# ===============================
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
DINGTALK_CORP_ID=your_corp_id

# ===============================
# Flask Security (required)
# ===============================
FLASK_SECRET_KEY=replace_with_strong_random_secret

# ===============================
# Optional runtime settings
# ===============================
REQUEST_TIMEOUT_SECONDS=10
DINGTALK_OAPI_BASE=https://oapi.dingtalk.com
# Optional: user id used by /admin/process_instances fallback
DINGTALK_ADMIN_USERID=100953685930636756

# ===============================
# Optional path overrides
# ===============================
PDF_TEMPLATE_DIR=/root/dingtalk-h5-app/templates/pdf_templates
OUTPUT_DIR=/root/dingtalk-h5-app/static/outputs
PROCESS_CONFIG_FILE=/root/dingtalk-h5-app/data/process_configs.json
PROCESS_HISTORY_FILE=/root/dingtalk-h5-app/data/process_configs.history.json
# Reserved for future node-level signature/date mapping
PROCESS_NODE_CONFIG_TEMPLATE_FILE=/root/dingtalk-h5-app/data/process_node_configs.template.json

