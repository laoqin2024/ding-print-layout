# ===============================
# 环境变量和敏感信息
# ===============================
.env
.env.local
.env.*.local

# ===============================
# Python
# ===============================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ===============================
# 虚拟环境
# ===============================
venv/
dingvenv/
ENV/
env/
.venv

# ===============================
# IDE
# ===============================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ===============================
# 项目特定文件
# ===============================
# 生成的 PDF 输出
static/outputs/*.pdf
!static/outputs/.gitkeep

# 用户上传的 PDF 模板（可能包含敏感信息）
templates/pdf_templates/*.pdf
!templates/pdf_templates/.gitkeep

# ===============================
# 数据文件 (安全白名单策略)
# ===============================
# 忽略 data 目录下所有的真实数据文件（包含所有业务表单、用户、权限等）
data/*

# 仅允许提交必要的示例文档和基础配置结构
!data/*.md
!data/*.example.json
!data/*.template.json
!data/.gitkeep

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.temp
.cache/

# ===============================
# 测试和覆盖率
# ===============================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
tests/

# ===============================
# 数据库
# ===============================
*.db
*.sqlite
*.sqlite3

# ===============================
# 备份文件
# ===============================
*.bak
*.backup
*~

# ===============================
# 操作系统
# ===============================
.DS_Store
Thumbs.db
desktop.ini

# ===============================
# 开发文档（不提交）
# ===============================
docs/
*.md.backup

# ===============================
# 前端构建产物（如果有）
# ===============================
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# ===============================
# Cursor 相关
# ===============================
.cursor/

